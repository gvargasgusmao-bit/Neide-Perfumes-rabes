<%- include('partials/header', {
  meta: {
    title: (perfume.nome + ' | Neide Perfumes Importados'),
    description: (perfume.descricao_curta || 'Perfume árabe importado. Notas exclusivas, alta fixação e projeção. Disponível na Neide Perfumes Importados.'),
    canonical: '/perfume/' + perfume.slug
  },
  config
}) %>

<div class="produto-pagina">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="produto-breadcrumb" aria-label="Navegação estrutural">
      <a href="/" id="bc-home">Home</a>
      <span class="produto-breadcrumb-sep" aria-hidden="true">›</span>
      <a href="/catalogo" id="bc-catalogo">Catálogo</a>
      <span class="produto-breadcrumb-sep" aria-hidden="true">›</span>
      <span aria-current="page"><%= perfume.nome %></span>
    </nav>

    <!-- Layout 2 colunas -->
    <div class="produto-grid">

      <!-- ===== COLUNA ESQUERDA — Galeria ===== -->
      <div class="produto-galeria">
        <div class="produto-imagem-principal">
          <!-- Badges na imagem -->
          <div class="produto-badges-imagem">
            <% if (perfume.genero === 'masculino') { %>
              <span class="badge badge-genero-m">Masculino</span>
            <% } else if (perfume.genero === 'feminino') { %>
              <span class="badge badge-genero-f">Feminino</span>
            <% } else { %>
              <span class="badge badge-genero-u">Unissex</span>
            <% } %>
            <% if (perfume.status_estoque === 'ultimo_item') { %>
              <span class="badge badge-estoque-ultimo">⚠️ Último item</span>
            <% } else { %>
              <span class="badge badge-estoque-ok">✓ Disponível</span>
            <% } %>
            <% if (perfume.badges && perfume.badges.length > 0) { %>
              <% perfume.badges.slice(0, 2).forEach(b => { %>
                <span class="badge badge-conversao" style="margin-top: 4px;"><%= b %></span>
              <% }) %>
            <% } %>
          </div>

          <!-- Imagem principal -->
          <% if (perfume.imagem_url) { %>
            <img src="<%= perfume.imagem_url %>" alt="<%= perfume.nome %>" style="width:100%; height:100%; object-fit:cover; display:block; border-radius: 20px;" onerror="this.onerror=null; this.src='https://placehold.co/400x500/1a1a1a/d4af37?text=Imagem+Indisponível';">
          <% } else { %>
            <div class="produto-imagem-placeholder">
              <div class="produto-imagem-placeholder-icone" aria-hidden="true">🌹</div>
              <div class="produto-imagem-placeholder-nome"><%= perfume.nome %></div>
              <div class="label-categoria" style="margin-top:8px;"><%= marca ? marca.nome : 'Importado' %></div>
            </div>
          <% } %>
        </div>

        <!-- Compartilhar via WhatsApp (mobile-friendly) -->
        <a href="https://wa.me/<%= config.whatsapp_contato %>?text=<%= encodeURIComponent('Olá, Neide Perfumes! Vi o perfume "' + perfume.nome + '" no site e quero saber mais!') %>"
           class="btn btn-whatsapp"
           style="width:100%;margin-top:1rem;"
           target="_blank"
           rel="noopener noreferrer"
           id="produto-wa-galeria">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Comprar via WhatsApp
        </a>
      </div>

      <!-- ===== COLUNA DIREITA — Informações ===== -->
      <div class="produto-info">

        <!-- Cabeçalho -->
        <div class="produto-marca"><%= marca ? marca.nome : 'Importado' %></div>
        <h1 class="produto-nome"><%= perfume.nome %></h1>
        <div class="produto-volume">
          <%= perfume.volume_ml %> ml
          <% if (perfume.familia_olfativa) { %>
            • <span style="text-transform:capitalize;"><%= perfume.familia_olfativa %></span>
          <% } %>
        </div>

        <!-- Preço -->
        <div class="produto-preco">
          <% if (perfume.preco_sob_consulta) { %>
            Sob Consulta
          <% } else { %>
            R$ <%= (perfume.preco || 0).toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
          <% } %>
        </div>

        <!-- Métricas Fixação / Projeção -->
        <% if (perfume.fixacao || perfume.projecao) { %>
        <div class="produto-metricas">
          <div>
            <div class="produto-metrica-label">Fixação</div>
            <div class="produto-metrica-barra">
              <div class="produto-metrica-fill" style="width:<%= ((perfume.fixacao || 3) / 5) * 100 %>%;"></div>
            </div>
            <div class="produto-metrica-nivel">
              <% const fixNivel = ['','Muito Suave','Suave','Moderada','Alta','Muito Alta']; %>
              <%= fixNivel[perfume.fixacao || 3] %> (<%= perfume.fixacao || 3 %>/5)
            </div>
          </div>
          <div>
            <div class="produto-metrica-label">Projeção</div>
            <div class="produto-metrica-barra">
              <div class="produto-metrica-fill" style="width:<%= ((perfume.projecao || 3) / 5) * 100 %>%;"></div>
            </div>
            <div class="produto-metrica-nivel">
              <% const projNivel = ['','Íntima','Suave','Moderada','Alta','Silagem Longa']; %>
              <%= projNivel[perfume.projecao || 3] %> (<%= perfume.projecao || 3 %>/5)
            </div>
          </div>
        </div>
        <% } %>

        <!-- Ocasiões -->
        <% if (perfume.ocasiao && perfume.ocasiao.length > 0) { %>
        <div class="produto-ocasioes">
          <div class="produto-ocasioes-titulo">Ocasiões Recomendadas</div>
          <div class="produto-ocasioes-lista">
            <% const emojiOcasiao = {trabalho:'💼',dia_a_dia:'☀️',academia:'🏋️',encontros:'❤️',eventos:'🎭',festas:'🎉',uso_noturno:'🌙'}; %>
            <% perfume.ocasiao.forEach(o => { %>
              <span class="produto-ocasiao-badge">
                <%= emojiOcasiao[o] || '' %> <%= o.replace('_', ' ') %>
              </span>
            <% }) %>
          </div>
        </div>
        <% } %>

        <!-- Similares Famosos -->
        <% if (perfume.similares_famosos && perfume.similares_famosos.length > 0) { %>
        <div class="produto-similares-destaque" style="background: rgba(212, 175, 55, 0.1); border: 1px solid var(--dourado); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center;">
          <div style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--dourado);">✨ <strong>Gosta do <%= perfume.similares_famosos[0].split(' ').slice(0,3).join(' ') %>?</strong></div>
          <p style="color: var(--branco-80); margin-bottom: 0; line-height: 1.5;">Se você gosta de fragrâncias como <strong style="color:var(--branco)"><%= perfume.similares_famosos.join(' ou ') %></strong>, você provavelmente vai se apaixonar por este perfume árabe.</p>
        </div>
        <% } %>

        <!-- Pirâmide Olfativa -->
        <% const piramide = perfume.piramide_olfativa || {}; %>
        <div class="piramide">
          <h2 class="piramide-titulo">Pirâmide Olfativa</h2>
          <div class="piramide-camadas">

            <div class="piramide-camada topo">
              <div class="piramide-camada-label">
                Notas de Topo
                <small>Primeiras impressões • evaporam em 15-30min</small>
              </div>
              <div class="piramide-camada-notas">
                <% (piramide.topo || ['A definir']).forEach(nota => { %>
                  <span class="piramide-nota" <%= nota.toLowerCase().includes('definir') ? 'style="opacity:0.4;"' : '' %>><%= nota %></span>
                <% }) %>
              </div>
            </div>

            <div class="piramide-camada coracao">
              <div class="piramide-camada-label">
                Notas de Coração
                <small>A alma do perfume • duram 2-4 horas</small>
              </div>
              <div class="piramide-camada-notas">
                <% (piramide.coracao || ['A definir']).forEach(nota => { %>
                  <span class="piramide-nota" <%= nota.toLowerCase().includes('definir') ? 'style="opacity:0.4;"' : '' %>><%= nota %></span>
                <% }) %>
              </div>
            </div>

            <div class="piramide-camada fundo">
              <div class="piramide-camada-label">
                Notas de Fundo
                <small>Fixação e profundidade • duram 6-24h</small>
              </div>
              <div class="piramide-camada-notas">
                <% (piramide.fundo || ['A definir']).forEach(nota => { %>
                  <span class="piramide-nota" <%= nota.toLowerCase().includes('definir') ? 'style="opacity:0.4;"' : '' %>><%= nota %></span>
                <% }) %>
              </div>
            </div>

          </div>
        </div>

        <!-- CTA de Compra -->
        <div class="produto-cta">
          <div class="produto-cta-estoque">
            <div class="produto-cta-ponto" aria-hidden="true"></div>
            <% if (perfume.status_estoque === 'ultimo_item') { %>
              <span style="color:var(--alerta);font-weight:500;">Último item disponível</span>
            <% } else { %>
              <span style="color:var(--sucesso);font-weight:500;">Disponível em estoque</span>
            <% } %>
          </div>

          <a href="https://wa.me/<%= config.whatsapp_contato %>?text=<%= encodeURIComponent('Olá, Neide Perfumes! Quero comprar o perfume "' + perfume.nome + '" de ' + (marca ? marca.nome : '') + '. Pode me dar mais informações?') %>"
             class="btn btn-primario produto-cta-btn"
             target="_blank"
             rel="noopener noreferrer"
             id="produto-btn-comprar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Quero este perfume →
          </a>

          <a href="https://wa.me/<%= config.whatsapp_contato %>?text=<%= encodeURIComponent('Olá! Estou vendo o perfume "' + perfume.nome + '" e tenho algumas dúvidas. Pode me ajudar?') %>"
             class="btn btn-ghost produto-cta-btn"
             target="_blank"
             rel="noopener noreferrer"
             id="produto-btn-duvidas">
            💬 Tirar dúvidas
          </a>

          <p class="produto-cta-disclaimer">
            Atendimento via WhatsApp • Envio para todo o Brasil • Perfume 100% original
          </p>
        </div>

        <!-- Descrição -->
        <% if (perfume.descricao_longa) { %>
        <div class="produto-descricao">
          <h2 class="produto-descricao-titulo">Sobre este perfume</h2>
          <p class="produto-descricao-texto"><%= perfume.descricao_longa %></p>
        </div>
        <% } %>

      </div><!-- fim produto-info -->
    </div><!-- fim produto-grid -->

    <!-- ===== PERFUMES RELACIONADOS ===== -->
    <% if (relacionados && relacionados.length > 0) { %>
    <section class="secao-relacionados" aria-label="Perfumes relacionados">
      <div class="texto-centro" style="margin-bottom:2rem;">
        <div class="label-categoria">Continue Explorando</div>
        <div class="linha-dourada"></div>
        <h2 class="titulo-secao">Você também pode gostar</h2>
      </div>
      <div class="grade-perfumes">
        <% relacionados.slice(0, 4).forEach(r => { %>
          <%
            const mRel = marcas.find(m => m.id_marca === r.id_marca);
            const nomeMarcaRel = mRel ? mRel.nome : 'Importado';
          %>
          <article class="perfume-card" aria-label="<%= r.nome %>">
            <a href="/perfume/<%= r.slug %>" class="perfume-card-imagem" aria-label="Ver <%= r.nome %>">
              <% if (r.imagem_url) { %>
                <img src="<%= r.imagem_url %>" alt="<%= r.nome %>" class="perfume-card-imagem-img" loading="lazy">
              <% } else { %>
                <div class="perfume-card-placeholder shimmer">
                  <div class="perfume-placeholder-icone" aria-hidden="true">🌹</div>
                  <div class="perfume-placeholder-nome"><%= r.nome %></div>
                </div>
              <% } %>
              <div class="perfume-card-badges">
                <% if (r.genero === 'masculino') { %><span class="badge badge-genero-m">Masculino</span>
                <% } else if (r.genero === 'feminino') { %><span class="badge badge-genero-f">Feminino</span>
                <% } else { %><span class="badge badge-genero-u">Unissex</span><% } %>
              </div>
            </a>
            <div class="perfume-card-info">
              <div class="perfume-card-marca"><%= nomeMarcaRel %></div>
              <a href="/perfume/<%= r.slug %>" class="perfume-card-nome"><%= r.nome %></a>
              <div class="perfume-card-footer">
                <div class="perfume-card-preco">
                  <%= r.preco_sob_consulta ? 'Sob Consulta' : 'R$ ' + (r.preco || 0).toLocaleString('pt-BR', {minimumFractionDigits: 0}) %>
                </div>
                <a href="/perfume/<%= r.slug %>" class="perfume-card-botao">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
    <% } %>

  </div><!-- fim container -->
</div><!-- fim produto-pagina -->

<%- include('partials/footer') %>